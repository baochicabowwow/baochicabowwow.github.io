    "@tanstack/react-query": "^5.60.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-document-picker": "~13.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.2",
    "expo-image-picker": "~16.0.0",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "papaparse": "^5.4.0",
    "react": "18.3.1",
