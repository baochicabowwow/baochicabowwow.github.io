    "@types/jest": "^30.0.0",
    "@types/papaparse": "^5.3.0",
    "@types/react": "~18.3.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "dotenv": "^16.4.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.3.3"
